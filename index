<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>🍊 南高教园区 · 新生美食雷达</title>
    <style>
        /* ========== 全局重置 & CSS 变量 ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #f97316;
            --primary-dark: #ea580c;
            --primary-light: #fb923c;
            --primary-gradient: linear-gradient(145deg, #f97316, #ef4444);
            --bg-start: #fef3c7;
            --bg-end: #fce7f3;
            --card-bg: rgba(255, 255, 255, 0.78);
            --card-border: rgba(255, 255, 255, 0.5);
            --shadow-sm: 0 4px 24px rgba(0, 0, 0, 0.04);
            --shadow-md: 0 8px 40px rgba(0, 0, 0, 0.06);
            --radius: 18px;
            --radius-sm: 12px;
            --text: #1e293b;
            --text-secondary: #64748b;
            --text-light: #94a3b8;
            --success: #22c55e;
            --danger: #ef4444;
            --warning: #f59e0b;
            --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font);
            background: radial-gradient(ellipse at 20% 20%, var(--bg-start), var(--bg-end));
            background-attachment: fixed;
            min-height: 100vh;
            color: var(--text);
            padding-bottom: 60px;
        }

        /* ========== 滚动条美化 ========== */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--primary-light);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

        /* ========== 工具类 ========== */
        .hidden {
            display: none !important;
        }
        .text-center {
            text-align: center;
        }
        .flex-center {
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .gap-2 {
            gap: 8px;
        }
        .gap-4 {
            gap: 16px;
        }
        .w-full {
            width: 100%;
        }
        .mt-2 {
            margin-top: 8px;
        }
        .mt-4 {
            margin-top: 16px;
        }
        .mb-2 {
            margin-bottom: 8px;
        }
        .mb-4 {
            margin-bottom: 16px;
        }

        /* ========== Header ========== */
        header {
            background: var(--primary-gradient);
            color: #fff;
            padding: 32px 20px 28px;
            text-align: center;
            border-radius: 0 0 var(--radius) var(--radius);
            box-shadow: 0 12px 40px rgba(249, 115, 22, 0.25);
            position: relative;
            overflow: hidden;
        }

        header::after {
            content: '🍜';
            position: absolute;
            right: -10px;
            bottom: -20px;
            font-size: 120px;
            opacity: 0.08;
            pointer-events: none;
            transform: rotate(-8deg);
        }

        header h1 {
            font-size: 26px;
            font-weight: 800;
            letter-spacing: -0.5px;
            text-shadow: 0 2px 12px rgba(0, 0, 0, 0.10);
        }

        header p {
            margin-top: 6px;
            font-size: 14px;
            opacity: 0.92;
            font-weight: 400;
            letter-spacing: 0.3px;
        }

        /* ---- 用户状态栏 ---- */
        .user-status-bar {
            position: absolute;
            top: 14px;
            right: 16px;
            background: rgba(255, 255, 255, 0.18);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            padding: 5px 14px 5px 18px;
            border-radius: 40px;
            font-size: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .user-status-bar .uname {
            font-weight: 700;
            max-width: 100px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .user-status-bar .role-tag {
            background: rgba(255, 255, 255, 0.2);
            padding: 2px 10px;
            border-radius: 30px;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }

        .logout-btn {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: #fff;
            padding: 3px 12px;
            border-radius: 30px;
            font-size: 11px;
            cursor: pointer;
            transition: var(--transition);
            font-weight: 500;
        }
        .logout-btn:hover {
            background: rgba(255, 255, 255, 0.30);
        }

        /* ========== 容器 ========== */
        .container {
            max-width: 700px;
            margin: -18px auto 0;
            padding: 0 16px;
            position: relative;
            z-index: 10;
        }

        /* ========== 毛玻璃面板 ========== */
        .glass {
            background: var(--card-bg);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid var(--card-border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            padding: 20px 22px;
            margin-bottom: 18px;
            transition: var(--transition);
        }

        .glass:hover {
            box-shadow: var(--shadow-md);
        }

        /* ========== 登录 / 注册面板 ========== */
        #auth-section .auth-toggle {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 18px;
            font-weight: 600;
            font-size: 15px;
        }

        #auth-section .auth-toggle span {
            cursor: pointer;
            padding-bottom: 6px;
            color: var(--text-secondary);
            border-bottom: 3px solid transparent;
            transition: var(--transition);
        }

        #auth-section .auth-toggle span.active {
            color: var(--primary);
            border-bottom-color: var(--primary);
        }

        .auth-input {
            display: block;
            width: 100%;
            max-width: 320px;
            margin: 0 auto 14px;
            padding: 13px 16px;
            border: 1.5px solid rgba(0, 0, 0, 0.06);
            border-radius: var(--radius-sm);
            font-size: 14px;
            background: rgba(255, 255, 255, 0.7);
            transition: var(--transition);
            outline: none;
            font-family: var(--font);
        }

        .auth-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.10);
            background: #fff;
        }

        .auth-input::placeholder {
            color: var(--text-light);
        }

        .auth-select {
            display: block;
            width: 100%;
            max-width: 320px;
            margin: 0 auto 14px;
            padding: 13px 16px;
            border: 1.5px solid rgba(0, 0, 0, 0.06);
            border-radius: var(--radius-sm);
            font-size: 14px;
            background: rgba(255, 255, 255, 0.7);
            transition: var(--transition);
            outline: none;
            font-family: var(--font);
            color: var(--text);
            cursor: pointer;
        }

        .auth-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.10);
        }

        .btn-primary {
            display: inline-block;
            padding: 13px 32px;
            background: var(--primary-gradient);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: var(--transition);
            box-shadow: 0 4px 16px rgba(249, 115, 22, 0.25);
            font-family: var(--font);
            letter-spacing: 0.3px;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(249, 115, 22, 0.30);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

        /* ========== 统计卡片 ========== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 6px;
        }

        .stat-item {
            text-align: center;
            padding: 12px 6px;
            background: rgba(255, 255, 255, 0.5);
            border-radius: var(--radius-sm);
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .stat-item .num {
            font-size: 26px;
            font-weight: 800;
            line-height: 1.2;
        }

        .stat-item .label {
            font-size: 11px;
            color: var(--text-secondary);
            font-weight: 500;
            margin-top: 2px;
        }

        .stat-item .num.gold {
            color: var(--warning);
        }
        .stat-item .num.green {
            color: var(--success);
        }
        .stat-item .num.red {
            color: var(--danger);
        }

        /* ========== 搜索筛选 ========== */
        .search-box {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .search-box select,
        .search-box input {
            padding: 11px 14px;
            border: 1.5px solid rgba(0, 0, 0, 0.06);
            border-radius: var(--radius-sm);
            font-size: 14px;
            background: rgba(255, 255, 255, 0.7);
            outline: none;
            transition: var(--transition);
            font-family: var(--font);
            color: var(--text);
        }

        .search-box select {
            flex: 0 0 auto;
            min-width: 110px;
            cursor: pointer;
        }

        .search-box input {
            flex: 1;
            min-width: 140px;
        }

        .search-box select:focus,
        .search-box input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.08);
            background: #fff;
        }

        .search-box input::placeholder {
            color: var(--text-light);
        }

        /* ========== 排序切换 ========== */
        .sort-bar {
            display: flex;
            gap: 8px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .sort-btn {
            padding: 5px 14px;
            border: 1.5px solid rgba(0, 0, 0, 0.06);
            border-radius: 40px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.5);
            color: var(--text-secondary);
            transition: var(--transition);
            font-family: var(--font);
        }

        .sort-btn:hover {
            background: rgba(255, 255, 255, 0.8);
            color: var(--text);
        }

        .sort-btn.active {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
        }

        /* ========== 内容卡片 ========== */
        .section-title {
            font-size: 18px;
            font-weight: 800;
            color: var(--text);
            margin: 8px 0 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title .count {
            font-size: 13px;
            font-weight: 500;
            color: var(--text-secondary);
            margin-left: auto;
        }

        .feed-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            padding: 18px 20px 20px;
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            margin-bottom: 14px;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .feed-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

        /* 左侧色条 */
        .feed-card::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            width: 5px;
            height: 100%;
            border-radius: 0 4px 4px 0;
        }

        .feed-card.type-red::before {
            background: var(--success);
        }
        .feed-card.type-black::before {
            background: var(--danger);
        }

        .feed-card .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
            flex-wrap: wrap;
        }

        .feed-card .store-name {
            font-size: 18px;
            font-weight: 800;
            color: var(--text);
            line-height: 1.3;
        }

        .feed-card .badge {
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 11px;
            font-weight: 700;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .badge-red {
            background: #fef2f2;
            color: var(--danger);
            border: 1px solid #fecaca;
        }
        .badge-green {
            background: #f0fdf4;
            color: var(--success);
            border: 1px solid #bbf7d0;
        }

        .feed-card .meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px 18px;
            font-size: 12px;
            color: var(--text-secondary);
            margin: 10px 0 12px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(0, 0, 0, 0.04);
        }

        .feed-card .meta span {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .feed-card .review-text {
            font-size: 14px;
            line-height: 1.7;
            color: var(--text);
            padding: 12px 16px;
            background: rgba(0, 0, 0, 0.02);
            border-radius: var(--radius-sm);
            border-left: 3px solid rgba(0, 0, 0, 0.06);
            word-break: break-word;
        }

        .feed-card .card-actions {
            display: flex;
            gap: 12px;
            margin-top: 14px;
            justify-content: flex-end;
            align-items: center;
        }

        .feed-card .card-actions .action-btn {
            background: none;
            border: none;
            font-size: 13px;
            color: var(--text-secondary);
            cursor: pointer;
            transition: var(--transition);
            padding: 4px 8px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 4px;
            font-family: var(--font);
        }

        .feed-card .card-actions .action-btn:hover {
            background: rgba(0, 0, 0, 0.04);
            color: var(--text);
        }

        .feed-card .card-actions .action-btn.danger:hover {
            color: var(--danger);
            background: rgba(239, 68, 68, 0.08);
        }

        /* ========== 空状态 ========== */
        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-secondary);
        }

        .empty-state .icon {
            font-size: 48px;
            margin-bottom: 12px;
            opacity: 0.6;
        }

        .empty-state p {
            font-size: 14px;
        }

        /* ========== 发布表单 ========== */
        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-secondary);
            margin-bottom: 5px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 11px 14px;
            border: 1.5px solid rgba(0, 0, 0, 0.06);
            border-radius: var(--radius-sm);
            font-size: 14px;
            background: rgba(255, 255, 255, 0.7);
            outline: none;
            transition: var(--transition);
            font-family: var(--font);
            color: var(--text);
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.08);
            background: #fff;
        }

        .form-group textarea {
            resize: vertical;
            min-height: 80px;
        }

        .form-group .hint {
            font-size: 12px;
            color: var(--text-light);
            margin-top: 4px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        /* ========== Toast 通知 ========== */
        #toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 360px;
            width: calc(100% - 40px);
            pointer-events: none;
        }

        .toast {
            padding: 14px 20px;
            border-radius: var(--radius-sm);
            color: #fff;
            font-weight: 500;
            font-size: 14px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.10);
            pointer-events: auto;
            animation: slideIn 0.35s cubic-bezier(0.22, 1, 0.36, 1);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .toast.success {
            background: rgba(34, 197, 94, 0.92);
        }
        .toast.error {
            background: rgba(239, 68, 68, 0.92);
        }
        .toast.info {
            background: rgba(59, 130, 246, 0.92);
        }
        .toast.warning {
            background: rgba(245, 158, 11, 0.92);
        }

        .toast .toast-icon {
            font-size: 20px;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(40px) scale(0.96);
            }
            to {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        /* ========== 响应式 ========== */
        @media (max-width: 600px) {
            header {
                padding: 24px 16px 20px;
            }
            header h1 {
                font-size: 20px;
            }
            header p {
                font-size: 12px;
            }

            .user-status-bar {
                top: 10px;
                right: 12px;
                padding: 3px 10px 3px 14px;
                font-size: 11px;
                gap: 8px;
                flex-wrap: wrap;
                justify-content: flex-end;
            }
            .user-status-bar .uname {
                max-width: 70px;
            }

            .container {
                padding: 0 12px;
            }

            .glass {
                padding: 16px;
            }

            .stats-grid {
                grid-template-columns: repeat(3, 1fr);
                gap: 8px;
            }
            .stat-item .num {
                font-size: 20px;
            }

            .search-box {
                flex-direction: column;
            }
            .search-box select {
                width: 100%;
            }

            .form-row {
                grid-template-columns: 1fr;
            }

            .feed-card {
                padding: 14px 16px;
            }
            .feed-card .store-name {
                font-size: 16px;
            }
            .feed-card .review-text {
                font-size: 13px;
                padding: 10px 12px;
            }

            #auth-section .auth-toggle {
                font-size: 13px;
                gap: 12px;
            }
            .auth-input,
            .auth-select {
                max-width: 100%;
            }
            .btn-primary {
                padding: 12px 24px;
                font-size: 14px;
                width: 100%;
            }

            .sort-bar {
                gap: 6px;
            }
            .sort-btn {
                font-size: 11px;
                padding: 4px 12px;
            }

            #toast-container {
                top: 12px;
                right: 12px;
                max-width: calc(100% - 24px);
            }
            .toast {
                font-size: 13px;
                padding: 12px 16px;
            }
        }

        @media (max-width: 420px) {
            .stats-grid {
                grid-template-columns: 1fr 1fr 1fr;
                gap: 6px;
            }
            .stat-item .num {
                font-size: 18px;
            }
            .stat-item .label {
                font-size: 10px;
            }
            .user-status-bar .role-tag {
                display: none;
            }
        }
    </style>
</head>

<body>

    <!-- ===== HEADER ===== -->
    <header>
        <div id="userStatus" class="user-status-bar">
            <span class="uname">👋 未登录</span>
            <button class="logout-btn hidden" id="logoutBtn" onclick="App.logout()">退出</button>
        </div>
        <h1>🍊 南高教 · 美食雷达</h1>
        <p>学府一号 · 钱湖天地 · 万里步行街 — 新生专属纯民间避雷指南</p>
    </header>

    <!-- ===== CONTAINER ===== -->
    <div class="container">

        <!-- ===== 登录 / 注册 ===== -->
        <div id="authSection" class="glass">
            <div class="auth-toggle">
                <span id="tabLogin" class="active" onclick="App.setAuthMode('login')">🔐 登录</span>
                <span id="tabRegister" onclick="App.setAuthMode('register')">📝 注册</span>
            </div>
            <div id="authForm">
                <input type="text" id="authUsername" class="auth-input" placeholder="请输入用户名" autocomplete="username" />
                <div id="roleGroup" class="hidden">
                    <select id="authRole" class="auth-select">
                        <option value="freshman">🌱 大一新生（可看帖 · 发红榜）</option>
                        <option value="senior">🎓 大二及以上老生（可发黑榜）</option>
                    </select>
                </div>
                <button class="btn-primary w-full" onclick="App.handleAuth()">🚀 进入系统</button>
            </div>
        </div>

        <!-- ===== 主内容 ===== -->
        <div id="mainSection" class="hidden">

            <!-- 统计 -->
            <div class="glass">
                <div class="stats-grid" id="statsGrid">
                    <div class="stat-item"><div class="num gold" id="statTotal">0</div><div class="label">📊 总情报</div></div>
                    <div class="stat-item"><div class="num green" id="statRed">0</div><div class="label">👍 红榜</div></div>
                    <div class="stat-item"><div class="num red" id="statBlack">0</div><div class="label">⚠️ 黑榜</div></div>
                </div>
            </div>

            <!-- 搜索 & 排序 -->
            <div class="glass">
                <div class="search-box">
                    <select id="areaFilter" onchange="App.render()">
                        <option value="all">📍 全部商圈</option>
                        <option value="学府一号">学府一号</option>
                        <option value="钱湖天地">钱湖天地</option>
                        <option value="万里步行街">万里步行街</option>
                    </select>
                    <input type="text" id="searchInput" placeholder="🔍 搜店名 / 菜品 / 关键词…" oninput="App.render()" />
                </div>
                <div class="sort-bar">
                    <button class="sort-btn active" data-sort="newest" onclick="App.setSort('newest')">🕐 最新</button>
                    <button class="sort-btn" data-sort="price-asc" onclick="App.setSort('price-asc')">💰 价格低→高</button>
                    <button class="sort-btn" data-sort="price-desc" onclick="App.setSort('price-desc')">💰 价格高→低</button>
                </div>
            </div>

            <!-- 内容列表 -->
            <div class="section-title">
                🔥 实时情报
                <span class="count" id="resultCount">共 0 条</span>
            </div>
            <div id="contentList"></div>

            <!-- 发布表单 -->
            <div class="glass">
                <h3 style="margin:0 0 14px 0;font-weight:800;display:flex;align-items:center;gap:8px;">
                    ✍️ 撰写食评
                    <span style="font-size:12px;font-weight:400;color:var(--text-secondary);margin-left:auto;">为新生指路</span>
                </h3>
                <div class="form-group">
                    <label>🏪 店铺名称</label>
                    <input type="text" id="formStore" placeholder="例：学府一号 某某泥炉烤肉" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>📍 商圈</label>
                        <select id="formArea">
                            <option value="学府一号">学府一号</option>
                            <option value="钱湖天地">钱湖天地</option>
                            <option value="万里步行街">万里步行街</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>📌 评价性质</label>
                        <select id="formType" onchange="App.checkPostPermission()">
                            <option value="红榜推荐">👍 红榜推荐（安利宝藏）</option>
                            <option value="黑榜避雷">⚠️ 黑榜避雷（老生权限）</option>
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label>💰 人均消费（元）</label>
                    <input type="number" id="formPrice" value="30" min="0" step="1" />
                </div>
                <div class="form-group">
                    <label>📝 真实大实话</label>
                    <textarea id="formContent" rows="3" placeholder="请详细描述优缺点，拒绝商家公关文，为新生提供真实参考。"></textarea>
                    <div class="hint">💡 你的每一条真实评价都在帮助学弟学妹避坑</div>
                </div>
                <button class="btn-primary w-full" onclick="App.submit()">📢 立即广播</button>
            </div>

        </div>
    </div>

    <!-- ===== Toast 容器 ===== -->
    <div id="toastContainer"></div>

    <!-- ============================================================ -->
    <!-- ===== JAVASCRIPT ===== -->
    <script>
        /**
         * ============================================================
         *  App — 南高教美食雷达 主程序
         *  优化点：
         *    1. 数据持久化 (localStorage)
         *    2. 用户系统 (登录/注册/注销)
         *    3. 情报 CRUD (增删)
         *    4. 搜索 + 筛选 + 排序
         *    5. 统计概览
         *    6. 权限控制 (老生才能发黑榜)
         *    7. XSS 防护 (HTML 转义)
         *    8. Toast 通知反馈
         *    9. 响应式 UI
         *   10. 代码模块化、注释清晰
         * ============================================================
         */
        const App = (function() {

            // ---------- 私有状态 ----------
            let currentUser = null; // { username, role }
            let authMode = 'login'; // 'login' | 'register'
            let sortBy = 'newest'; // 'newest' | 'price-asc' | 'price-desc'

            // ---------- DOM 缓存 ----------
            const $ = id => document.getElementById(id);
            const dom = {
                authSection: $('authSection'),
                mainSection: $('mainSection'),
                authUsername: $('authUsername'),
                authRole: $('authRole'),
                roleGroup: $('roleGroup'),
                tabLogin: $('tabLogin'),
                tabRegister: $('tabRegister'),
                userStatus: $('userStatus'),
                logoutBtn: $('logoutBtn'),
                contentList: $('contentList'),
                resultCount: $('resultCount'),
                areaFilter: $('areaFilter'),
                searchInput: $('searchInput'),
                formStore: $('formStore'),
                formArea: $('formArea'),
                formType: $('formType'),
                formPrice: $('formPrice'),
                formContent: $('formContent'),
                statTotal: $('statTotal'),
                statRed: $('statRed'),
                statBlack: $('statBlack'),
                sortBtns: document.querySelectorAll('.sort-btn'),
            };

            // ---------- 工具函数 ----------
            function escapeHtml(text) {
                if (!text) return '';
                const map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;',
                };
                return String(text).replace(/[&<>"']/g, c => map[c]);
            }

            function generateId() {
                return Date.now().toString(36) + Math.random().toString(36).slice(2, 8);
            }

            function timeAgo(dateStr) {
                const now = Date.now();
                const diff = now - new Date(dateStr).getTime();
                const mins = Math.floor(diff / 60000);
                if (mins < 1) return '刚刚';
                if (mins < 60) return mins + '分钟前';
                const hours = Math.floor(mins / 60);
                if (hours < 24) return hours + '小时前';
                const days = Math.floor(hours / 24);
                if (days < 30) return days + '天前';
                return new Date(dateStr).toLocaleDateString('zh-CN');
            }

            // ---------- Toast 通知 ----------
            function showToast(message, type = 'info', duration = 3000) {
                const container = $('toastContainer');
                const icons = {
                    success: '✅',
                    error: '❌',
                    warning: '⚠️',
                    info: '💡'
                };
                const toast = document.createElement('div');
                toast.className = `toast ${type}`;
                toast.innerHTML = `<span class="toast-icon">${icons[type] || '💡'}</span><span>${escapeHtml(message)}</span>`;
                container.appendChild(toast);
                setTimeout(() => {
                    toast.style.opacity = '0';
                    toast.style.transform = 'translateX(30px)';
                    toast.style.transition = '0.3s ease';
                    setTimeout(() => toast.remove(), 350);
                }, duration);
            }

            // ---------- 数据管理 ----------
            function getData() {
                try {
                    const raw = localStorage.getItem('foodRadar_data');
                    if (raw) return JSON.parse(raw);
                } catch (_) { /* ignore */ }
                // 默认初始数据
                return {
                    users: [
                        { username: '万里大三学姐', role: 'senior' },
                        { username: '钱湖路打工人', role: 'freshman' },
                    ],
                    reviews: [{
                        id: 'r1',
                        name: '学府一号 XX 旋转小火锅',
                        area: '学府一号',
                        type: '黑榜避雷',
                        price: 35,
                        text: '丸子全是面粉，汤底咸得发苦。吃完回宿舍拉了三天，新生千万别去交学费！',
                        author: '万里大二学长',
                        authorRole: 'senior',
                        createdAt: new Date(Date.now() - 3600000 * 2).toISOString(),
                    }, {
                        id: 'r2',
                        name: '钱湖天地 东北泥炉烤肉',
                        area: '钱湖天地',
                        type: '红榜推荐',
                        price: 65,
                        text: '肉量超级扎实！凭学生证还送一份大拉皮，宿舍开学聚餐首选，绝对不踩雷。',
                        author: '万里大三学姐',
                        authorRole: 'senior',
                        createdAt: new Date(Date.now() - 3600000 * 5).toISOString(),
                    }, {
                        id: 'r3',
                        name: '万里步行街 无名炸串',
                        area: '万里步行街',
                        type: '黑榜避雷',
                        price: 18,
                        text: '千万别点他们家的深夜外卖，用的油一股怪味，而且巨辣，第二天直接起不来床去实训！',
                        author: '钱湖一号路人',
                        authorRole: 'senior',
                        createdAt: new Date(Date.now() - 3600000 * 8).toISOString(),
                    }]
                };
            }

            function saveData(data) {
                localStorage.setItem('foodRadar_data', JSON.stringify(data));
            }

            function loadData() {
                return getData();
            }

            // ---------- 用户管理 ----------
            function findUser(username) {
                const data = loadData();
                return data.users.find(u => u.username === username) || null;
            }

            function addUser(username, role) {
                const data = loadData();
                if (data.users.some(u => u.username === username)) return false;
                data.users.push({ username, role });
                saveData(data);
                return true;
            }

            // ---------- 情报管理 ----------
            function getReviews() {
                const data = loadData();
                return data.reviews || [];
            }

            function addReview(review) {
                const data = loadData();
                data.reviews.unshift(review);
                saveData(data);
            }

            function deleteReview(id) {
                const data = loadData();
                data.reviews = data.reviews.filter(r => r.id !== id);
                saveData(data);
            }

            // ---------- 权限检查 ----------
            function canPostBlack(user) {
                return user && user.role === 'senior';
            }

            // ---------- 渲染逻辑 ----------
            function render() {
                if (!currentUser) return;

                // 1. 获取过滤数据
                const area = dom.areaFilter.value;
                const keyword = dom.searchInput.value.trim().toLowerCase();

                let list = getReviews();

                // 过滤
                list = list.filter(item => {
                    const matchArea = area === 'all' || item.area === area;
                    const matchKeyword = !keyword ||
                        item.name.toLowerCase().includes(keyword) ||
                        item.text.toLowerCase().includes(keyword);
                    return matchArea && matchKeyword;
                });

                // 排序
                if (sortBy === 'newest') {
                    list.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
                } else if (sortBy === 'price-asc') {
                    list.sort((a, b) => (a.price || 0) - (b.price || 0));
                } else if (sortBy === 'price-desc') {
                    list.sort((a, b) => (b.price || 0) - (a.price || 0));
                }

                // 2. 更新统计
                const all = getReviews();
                const redCount = all.filter(r => r.type === '红榜推荐').length;
                const blackCount = all.filter(r => r.type === '黑榜避雷').length;
                dom.statTotal.textContent = all.length;
                dom.statRed.textContent = redCount;
                dom.statBlack.textContent = blackCount;

                // 3. 更新结果数
                dom.resultCount.textContent = `共 ${list.length} 条`;

                // 4. 渲染列表
                if (list.length === 0) {
                    dom.contentList.innerHTML = `
                        <div class="empty-state">
                            <div class="icon">🍽️</div>
                            <p>暂无匹配的情报，<br />快来发布第一条真实评价吧！</p>
                        </div>
                    `;
                    return;
                }

                let html = '';
                list.forEach(item => {
                    const isBlack = item.type === '黑榜避雷';
                    const isOwner = currentUser && item.author === currentUser.username;
                    html += `
                        <div class="feed-card ${isBlack ? 'type-black' : 'type-red'}">
                            <div class="card-header">
                                <span class="store-name">${escapeHtml(item.name)}</span>
                                <span class="badge ${isBlack ? 'badge-red' : 'badge-green'}">
                                    ${isBlack ? '⚠️ 黑榜避雷' : '👍 红榜推荐'}
                                </span>
                            </div>
                            <div class="meta">
                                <span>📍 ${escapeHtml(item.area)}</span>
                                <span>💰 ¥${item.price || 0}</span>
                                <span>👤 ${escapeHtml(item.author)}</span>
                                <span>🕐 ${timeAgo(item.createdAt)}</span>
                            </div>
                            <div class="review-text">“${escapeHtml(item.text)}”</div>
                            <div class="card-actions">
                                ${isOwner ? `<button class="action-btn danger" onclick="App.deleteReview('${item.id}')">🗑️ 删除</button>` : ''}
                                <span style="font-size:12px;color:var(--text-light);">#${escapeHtml(item.area)}</span>
                            </div>
                        </div>
                    `;
                });

                dom.contentList.innerHTML = html;
            }

            // ---------- 更新排序按钮状态 ----------
            function updateSortButtons() {
                dom.sortBtns.forEach(btn => {
                    btn.classList.toggle('active', btn.dataset.sort === sortBy);
                });
            }

            // ---------- 公共 API ----------
            return {

                // ---- 认证 ----
                setAuthMode(mode) {
                    authMode = mode;
                    dom.tabLogin.classList.toggle('active', mode === 'login');
                    dom.tabRegister.classList.toggle('active', mode === 'register');
                    dom.roleGroup.classList.toggle('hidden', mode === 'login');
                    dom.authUsername.placeholder = mode === 'login' ? '请输入用户名' : '创建用户名';
                },

                handleAuth() {
                    const username = dom.authUsername.value.trim();
                    if (!username) {
                        showToast('请填写用户名', 'warning');
                        return;
                    }
                    if (username.length < 2) {
                        showToast('用户名至少 2 个字符', 'warning');
                        return;
                    }

                    if (authMode === 'login') {
                        const user = findUser(username);
                        if (!user) {
                            showToast('用户不存在，请先注册', 'error');
                            return;
                        }
                        currentUser = user;
                        showToast(`👋 欢迎回来，${username}！`, 'success');
                    } else {
                        // 注册
                        if (findUser(username)) {
                            showToast('用户名已被占用', 'error');
                            return;
                        }
                        const role = dom.authRole.value;
                        if (!addUser(username, role)) {
                            showToast('注册失败，请重试', 'error');
                            return;
                        }
                        currentUser = { username, role };
                        showToast(`🎉 注册成功！欢迎 ${username}`, 'success');
                    }

                    this.enterMain();
                },

                logout() {
                    currentUser = null;
                    dom.authSection.classList.remove('hidden');
                    dom.mainSection.classList.add('hidden');
                    dom.logoutBtn.classList.add('hidden');
                    dom.userStatus.innerHTML = `<span class="uname">👋 未登录</span>`;
                    dom.authUsername.value = '';
                    showToast('已安全退出', 'info');
                },

                enterMain() {
                    dom.authSection.classList.add('hidden');
                    dom.mainSection.classList.remove('hidden');
                    // 更新状态栏
                    const roleLabel = currentUser.role === 'senior' ? '🎓 老生' : '🌱 新生';
                    dom.userStatus.innerHTML = `
                        <span class="uname">${escapeHtml(currentUser.username)}</span>
                        <span class="role-tag">${roleLabel}</span>
                        <button class="logout-btn" onclick="App.logout()">退出</button>
                    `;
                    dom.logoutBtn.classList.remove('hidden');
                    // 检查黑榜权限
                    this.checkPostPermission();
                    // 渲染
                    this.render();
                },

                // ---- 渲染 ----
                render() {
                    render();
                },

                // ---- 排序 ----
                setSort(sort) {
                    sortBy = sort;
                    updateSortButtons();
                    this.render();
                },

                // ---- 权限检查 ----
                checkPostPermission() {
                    const type = dom.formType.value;
                    if (type === '黑榜避雷' && !canPostBlack(currentUser)) {
                        showToast('⚠️ 只有大二及以上老生才能发布黑榜避雷', 'warning');
                        dom.formType.value = '红榜推荐';
                    }
                },

                // ---- 提交情报 ----
                submit() {
                    if (!currentUser) {
                        showToast('请先登录', 'error');
                        return;
                    }

                    const name = dom.formStore.value.trim();
                    const area = dom.formArea.value;
                    const type = dom.formType.value;
                    const price = parseInt(dom.formPrice.value) || 0;
                    const text = dom.formContent.value.trim();

                    if (!name) {
                        showToast('请填写店铺名称', 'warning');
                        dom.formStore.focus();
                        return;
                    }
                    if (!text) {
                        showToast('请填写评价内容', 'warning');
                        dom.formContent.focus();
                        return;
                    }
                    if (text.length < 6) {
                        showToast('评价内容至少 6 个字，写详细点吧', 'warning');
                        return;
                    }

                    // 黑榜权限二次校验
                    if (type === '黑榜避雷' && !canPostBlack(currentUser)) {
                        showToast('❌ 发布失败：只有老生有权发布黑榜避雷', 'error');
                        dom.formType.value = '红榜推荐';
                        return;
                    }

                    const review = {
                        id: generateId(),
                        name,
                        area,
                        type,
                        price,
                        text,
                        author: currentUser.username,
                        authorRole: currentUser.role,
                        createdAt: new Date().toISOString(),
                    };

                    addReview(review);

                    // 清空表单
                    dom.formStore.value = '';
                    dom.formContent.value = '';
                    dom.formPrice.value = '30';

                    showToast('🚀 广播成功！情报已实时加入雷达', 'success');
                    this.render();
                },

                // ---- 删除情报 ----
                deleteReview(id) {
                    if (!currentUser) return;
                    const reviews = getReviews();
                    const item = reviews.find(r => r.id === id);
                    if (!item) return;
                    if (item.author !== currentUser.username) {
                        showToast('只能删除自己发布的情报', 'error');
                        return;
                    }
                    if (confirm(`确定要删除「${item.name}」的食评吗？`)) {
                        deleteReview(id);
                        showToast('已删除', 'info');
                        this.render();
                    }
                },

                // ---- 初始化 ----
                init() {
                    // 检查是否有已登录用户（本地存储无状态，每次刷新需重新登录）
                    // 但我们可以尝试从 localStorage 恢复上次登录状态（安全考虑，不自动恢复）
                    // 仅展示未登录状态
                    dom.authSection.classList.remove('hidden');
                    dom.mainSection.classList.add('hidden');
                    dom.logoutBtn.classList.add('hidden');
                    dom.userStatus.innerHTML = `<span class="uname">👋 未登录</span>`;
                    this.setAuthMode('login');

                    // 初始化排序按钮状态
                    updateSortButtons();

                    // 预填充示例数据（如果本地没有数据）
                    const data = loadData();
                    if (!data.reviews || data.reviews.length === 0) {
                        // 使用默认数据已在 getData 中处理
                        const defaultData = getData();
                        saveData(defaultData);
                    }

                    // 渲染空状态
                    dom.contentList.innerHTML = `
                        <div class="empty-state">
                            <div class="icon">🍽️</div>
                            <p>登录后查看学长学姐的真实评价<br />一起共建南高教美食地图</p>
                        </div>
                    `;

                    // 监听 Enter 键快速登录
                    dom.authUsername.addEventListener('keydown', (e) => {
                        if (e.key === 'Enter') this.handleAuth();
                    });

                    // 监听表单 Enter 键快速提交 (在 textarea 中不触发)
                    dom.formContent.addEventListener('keydown', (e) => {
                        if (e.key === 'Enter' && e.ctrlKey) {
                            e.preventDefault();
                            this.submit();
                        }
                    });

                    console.log('🍊 南高教美食雷达 已启动！');
                    console.log('📌 数据存储在 localStorage 中，刷新页面不会丢失。');
                }
            };

        })();

        // ---------- 启动 ----------
        document.addEventListener('DOMContentLoaded', () => App.init());
    </script>
</body>
</html>
